# Docker Compose project name. Keep stable for Chinese or arbitrary folder names.
COMPOSE_PROJECT_NAME=wjegov

# PostgreSQL
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=wjegov
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Application
PORT=38306
CORS_ORIGIN=*
